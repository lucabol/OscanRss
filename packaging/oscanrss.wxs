<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v5 installer definition for OscanRss.
  Build with:
    wix build packaging/oscanrss.wxs -d Version=0.1.0 -d BinDir=build -o oscanrss.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="OscanRss"
      Manufacturer="lucabol"
      Version="$(var.Version)"
      UpgradeCode="3C084F1F-25A1-4A1E-87AF-B9C1A236732B"
      Scope="perMachine"
      Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OscanRss">
        <Component Id="MainExe" Guid="*">
          <File Id="oscanrss.exe" Source="$(var.BinDir)\oscanrss.exe" KeyPath="yes" />
        </Component>
        <Component Id="Readme" Guid="*">
          <File Id="README.md" Source="README.md" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenu" Name="OscanRss">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="OscanRssShortcut"
                    Name="OscanRss"
                    Description="Feedly-style RSS reader"
                    Target="[INSTALLFOLDER]oscanrss.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="CleanupProgramMenu" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\lucabol\OscanRss"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="OscanRss" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="Readme" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Package>
</Wix>
