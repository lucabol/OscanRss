// OscanRss — A Feedly-style RSS feed reader
// Written in Oscan. GUI via built-in canvas.

use "types.osc"
use "url.osc"
use "http.osc"
use "rss_parse.osc"
use "html_render.osc"
use "storage.osc"
use "opml_parse.osc"
use "icon.osc"
use "libs/ui.osc"

// ─── Constants ───────────────────────────────────────────

let WIN_W: i32 = 1100;
let WIN_H: i32 = 700;
let TREE_W: i32 = 250;
let STATUS_H: i32 = 24;
let CHROME_H: i32 = 30;
let ROW_H: i32 = 20;
let POST_SPLIT: i32 = 350;
let BTN_W: i32 = 80;
let BTN_H: i32 = 22;

// Colors
let BG_COLOR: i32 = 30 * 65536 + 30 * 256 + 34;
let PANEL_BG: i32 = 38 * 65536 + 38 * 256 + 42;
let TITLE_COLOR: i32 = 255 * 65536 + 255 * 256 + 255;
let TEXT_COLOR: i32 = 200 * 65536 + 200 * 256 + 200;
let DIM_COLOR: i32 = 130 * 65536 + 130 * 256 + 130;
let UNREAD_COLOR: i32 = 100 * 65536 + 180 * 256 + 255;
let READ_COLOR: i32 = 100 * 65536 + 100 * 256 + 105;
let SELECT_BG: i32 = 55 * 65536 + 55 * 256 + 70;
let GROUP_COLOR: i32 = 220 * 65536 + 200 * 256 + 255;
let BADGE_COLOR: i32 = 255 * 65536 + 160 * 256 + 60;
let LINK_COLOR: i32 = 100 * 65536 + 149 * 256 + 237;
let BORDER_COLOR: i32 = 65 * 65536 + 65 * 256 + 70;
let STATUS_BG: i32 = 40 * 65536 + 40 * 256 + 44;
let DIALOG_BG: i32 = 50 * 65536 + 50 * 256 + 55;
let ERROR_COLOR: i32 = 230 * 65536 + 80 * 256 + 80;

// ─── Helpers ─────────────────────────────────────────────

fn! next_id(ids: [i32]) -> i32 {
    let mut mx: i32 = 0;
    for ni in 0..len(ids) {
        if ids[ni] > mx { mx = ids[ni]; };
    };
    mx + 1
}

fn! count_unread(posts: [Post], feed_id: i32, read_guids: map) -> i32 {
    let mut count: i32 = 0;
    for ci in 0..len(posts) {
        if posts[ci].feed_id == feed_id and not map_has(read_guids, posts[ci].guid) {
            count += 1;
        };
    };
    count
}

fn! count_group_unread(posts: [Post], feeds: [Feed], group_id: i32, read_guids: map) -> i32 {
    let mut total: i32 = 0;
    for cg in 0..len(feeds) {
        if feeds[cg].group_id == group_id {
            total += count_unread(posts, feeds[cg].id, read_guids);
        };
    };
    total
}

fn! truncate_str(s: str, max_chars: i32) -> str {
    if str_len(s) <= max_chars * 1 {
        return s;
    };
    let chars: [i32] = str_to_chars(s);
    if len(chars) <= max_chars {
        return s;
    };
    let mut trunc: [i32] = [];
    for ti in 0..max_chars {
        push(trunc, chars[ti]);
    };
    push(trunc, 46); // '.'
    push(trunc, 46);
    push(trunc, 46);
    str_from_chars(trunc)
}

fn! text_buf_to_str(buf: [i32]) -> str {
    str_from_chars(buf)
}

fn! str_to_buf(s: str, buf: [i32]) {
    while len(buf) > 0 { pop(buf); };
    let chars: [i32] = str_to_chars(s);
    for sb in 0..len(chars) {
        push(buf, chars[sb]);
    };
}

// ─── Read State Persistence Helper ───────────────────────

fn! do_save_read(posts: [Post], read_guids: map) {
    let mut lines: [str] = [];
    let mut seen: map = map_new();
    for si in 0..len(posts) {
        let sg: str = posts[si].guid;
        if map_has(read_guids, sg) and not map_has(seen, sg) {
            push(lines, sg);
            map_set(seen, sg, "1");
        };
    };
    storage_save_read(lines);
}

// ─── Feed Fetching ───────────────────────────────────────

// Build a short list of candidate URLs to try for a feed, in priority order.
// Handles stale subdomains (blog. / feed. / feeds. / rss.) and http->https
// upgrades — the common cases where a feed URL moves.
fn! feed_candidate_urls(original: str) -> [str] {
    let mut out: [str] = [];
    push(out, original);

    let u: Url = url_parse(original);

    // http -> https on same host
    if str_eq(u.scheme, "http") {
        push(out, "https://{u.host}{u.path}");
    };

    // Strip common feed-ish subdomain prefixes and retry.
    let prefixes: [str] = ["blog.", "feed.", "feeds.", "rss."];
    for pi in 0..len(prefixes) {
        let p: str = prefixes[pi];
        if str_starts_with(u.host, p) {
            let stripped: str = str_slice(u.host, str_len(p), str_len(u.host));
            // Try https first since modern sites redirect anyway
            push(out, "https://{stripped}{u.path}");
            push(out, "http://{stripped}{u.path}");
        };
    };

    out
}

// Try each candidate URL in order; return the first that both fetches
// successfully AND parses into >= 1 item. Otherwise returns the last
// (failed) HttpResponse. The URL that worked is written to `resolved_url`.
fn! try_fetch_with_fallbacks(candidates: [str], resolved_url: [str]) -> HttpResponse {
    let mut last: HttpResponse = http_make_error("no candidates");
    let mut best: HttpResponse = http_make_error("no candidates");
    let mut have_best: bool = false;
    for ci in 0..len(candidates) {
        let r: HttpResponse = http_fetch_url(candidates[ci], 5);
        last = r;
        if r.ok and str_len(r.error) == 0 {
            let probe: [RssItem] = rss_parse_items(r.body);
            if len(probe) > 0 {
                while len(resolved_url) > 0 { pop(resolved_url); };
                push(resolved_url, candidates[ci]);
                return r;
            };
            // Remember first successful 2xx response so we can surface
            // a meaningful error (e.g. "got HTML, not a feed") rather
            // than a later candidate's DNS/404 error.
            if not have_best {
                best = r;
                have_best = true;
            };
        };
    };
    if have_best { return best; };
    last
}

// Apply an already-fetched HttpResponse to a feed: replace its posts and
// return a status message. Does NOT try URL fallbacks.
fn! apply_feed_response(feeds: [Feed], idx: i32, response: HttpResponse,
                        posts: [Post]) -> str {
    let feed: Feed = feeds[idx];
    if str_len(response.error) > 0 {
        return "Failed: {feed.name}: {response.error}";
    };
    if not response.ok {
        return "Failed: {feed.name}: HTTP {response.status_code}";
    };

    let items: [RssItem] = rss_parse_items(response.body);

    // Remove old posts for this feed
    let mut ri: i32 = len(posts) - 1;
    while ri >= 0 {
        if posts[ri].feed_id == feed.id {
            let last_idx: i32 = len(posts) - 1;
            if ri < last_idx { posts[ri] = posts[last_idx]; };
            pop(posts);
        };
        ri -= 1;
    };

    // Add new posts
    for fi2 in 0..len(items) {
        let item: RssItem = items[fi2];
        let post: Post = Post {
            feed_id: feed.id,
            title: item.title,
            link: item.link,
            description: item.description,
            pub_date: item.pub_date,
            guid: item.guid,
        };
        push(posts, post);
    };

    if len(items) == 0 {
        let ct: str = str_to_lower(response.content_type);
        if str_find(ct, "html") >= 0 {
            return "Failed: {feed.name}: got HTML, not a feed (URL is not RSS/Atom)";
        };
        return "No items: {feed.name} (not RSS/Atom?)";
    };

    "Loaded {len(items)} posts from {feed.name}"
}

fn! fetch_feed_posts(feeds: [Feed], idx: i32, posts: [Post], read_guids: map) -> str {
    if idx < 0 or idx >= len(feeds) { return "Invalid feed"; };
    let feed: Feed = feeds[idx];
    let candidates: [str] = feed_candidate_urls(feed.url);
    let mut resolved: [str] = [];
    let response: HttpResponse = try_fetch_with_fallbacks(candidates, resolved);

    let msg: str = apply_feed_response(feeds, idx, response, posts);
    if str_starts_with(msg, "Failed:") or str_starts_with(msg, "No items:") {
        return msg;
    };

    // If a different URL than the stored one worked, persist it.
    if len(resolved) > 0 and not str_eq(resolved[0], feed.url) {
        feeds[idx].url = resolved[0];
        storage_save_feeds(feeds);
        return "Loaded posts from {feed.name} (url updated)";
    };

    msg
}

// Wrapper: fetches a feed and records success/failure in `failed_feeds`
// (keyed by feed id as string). Returns the status message.
fn! fetch_and_track(feeds: [Feed], idx: i32, posts: [Post], read_guids: map, failed_feeds: map) -> str {
    let r: str = fetch_feed_posts(feeds, idx, posts, read_guids);
    let key: str = i32_to_str(feeds[idx].id);
    if str_starts_with(r, "Failed:") or str_starts_with(r, "No items:") {
        map_set(failed_feeds, key, r);
    } else {
        map_delete(failed_feeds, key);
    };
    r
}

// Render a full-screen loading overlay with a progress bar.
fn! render_loading(w: i32, h: i32, done: i32, total: i32, label: str) {
    canvas_clear(BG_COLOR);

    let title: str = "OscanRss - Loading feeds";
    let title_x: i32 = (w - str_len(title) * 8) / 2;
    gfx_draw_text(title_x, h / 2 - 60, title, TITLE_COLOR, 0);

    let msg: str = "{label}  ({done}/{total})";
    let msg_x: i32 = (w - str_len(msg) * 8) / 2;
    gfx_draw_text(msg_x, h / 2 - 30, msg, TEXT_COLOR, 0);

    // Progress bar
    let bar_w: i32 = if w < 520 { w - 80 } else { 480 };
    let bar_h: i32 = 14;
    let bar_x: i32 = (w - bar_w) / 2;
    let bar_y: i32 = h / 2;
    gfx_fill_rect(bar_x - 1, bar_y - 1, bar_w + 2, bar_h + 2, BORDER_COLOR);
    gfx_fill_rect(bar_x, bar_y, bar_w, bar_h, PANEL_BG);
    let fill_w: i32 = if total > 0 { (bar_w * done) / total } else { 0 };
    if fill_w > 0 {
        gfx_fill_rect(bar_x, bar_y, fill_w, bar_h, UNREAD_COLOR);
    };

    canvas_flush();
}


// the initial fetch in parallel using curl; feeds that fail the first
// pass are retried serially with URL fallback rewriting.
fn! refresh_all_feeds(feeds: [Feed], posts: [Post], read_guids: map,
                      failed_feeds: map, show_progress: bool) -> str {
    let mut n_ok: i32 = 0;
    let mut n_fail: i32 = 0;
    let total: i32 = len(feeds);

    let mut urls: [str] = [];
    for fu in 0..total {
        push(urls, feeds[fu].url);
    };

    let w0: i32 = canvas_width();
    let h0: i32 = canvas_height();
    if show_progress and total > 0 {
        render_loading(w0, h0, 0, total, "Starting...");
    };

    let state: ParallelFetch = http_parallel_start(urls, 8);
    let mut need_fallback: [i32] = [];

    if state.curl_ok {
        for ra in 0..total {
            if show_progress {
                render_loading(w0, h0, ra, total, "Fetching: {feeds[ra].name}");
            };
            let resp: HttpResponse = http_parallel_finish_one(state, ra);
            let msg: str = apply_feed_response(feeds, ra, resp, posts);
            let failed: bool = str_starts_with(msg, "Failed:") or str_starts_with(msg, "No items:");
            let key: str = i32_to_str(feeds[ra].id);
            if failed {
                // If the server responded 2xx with HTML, the URL is
                // reachable but simply isn't a feed — retrying with
                // subdomain-strip / scheme-swap candidates won't help
                // and would just slow startup. Record the error now.
                let ct_lc: str = str_to_lower(resp.content_type);
                let is_html: bool = resp.ok and str_find(ct_lc, "html") >= 0;
                if is_html {
                    map_set(failed_feeds, key, msg);
                    n_fail += 1;
                } else {
                    push(need_fallback, ra);
                };
            } else {
                map_delete(failed_feeds, key);
                n_ok += 1;
            };
        };
    } else {
        for rb in 0..total {
            push(need_fallback, rb);
        };
    };

    for nfi in 0..len(need_fallback) {
        let idx: i32 = need_fallback[nfi];
        if show_progress {
            render_loading(w0, h0, total - len(need_fallback) + nfi, total,
                           "Retrying: {feeds[idx].name}");
        };
        let r: str = fetch_feed_posts(feeds, idx, posts, read_guids);
        let key2: str = i32_to_str(feeds[idx].id);
        if str_starts_with(r, "Failed:") or str_starts_with(r, "No items:") {
            map_set(failed_feeds, key2, r);
            n_fail += 1;
        } else {
            map_delete(failed_feeds, key2);
            n_ok += 1;
        };
    };

    if show_progress {
        render_loading(w0, h0, total, total, "Done");
    };

    "Refreshed {n_ok} ok, {n_fail} failed"
}

// ─── Rendering ───────────────────────────────────────────

fn! render_chrome(w: i32) {
    gfx_fill_rect(0, 0, w, CHROME_H, STATUS_BG);
    gfx_draw_text(10, 8, "OscanRSS - Feed Reader", TITLE_COLOR, 0);
    gfx_line(0, CHROME_H, w, CHROME_H, BORDER_COLOR);
}

fn! render_status(w: i32, h: i32, total_unread: i32, status_msg: str) {
    let sy: i32 = h - STATUS_H;
    gfx_fill_rect(0, sy, w, STATUS_H, STATUS_BG);
    gfx_line(0, sy, w, sy, BORDER_COLOR);
    gfx_draw_text(10, sy + 6, "{total_unread} unread", TEXT_COLOR, 0);
    if str_len(status_msg) > 0 {
        gfx_draw_text(200, sy + 6, status_msg, DIM_COLOR, 0);
    };
}

fn! render_tree_panel(groups: [FeedGroup], feeds: [Feed], posts: [Post],
                      read_guids: map, sel_group: i32, sel_feed: i32,
                      tree_scroll: i32, panel_h: i32, prev_btn: i32,
                      tree_w: i32, failed_feeds: map) -> i32 {
    let px: i32 = 0;
    let py: i32 = CHROME_H;
    gfx_fill_rect(px, py, tree_w, panel_h, PANEL_BG);
    gfx_line(tree_w, py, tree_w, py + panel_h, BORDER_COLOR);

    let mut draw_y: i32 = py + 6 - tree_scroll;
    let mut clicked_type: i32 = -1; // -1 = none, 0..N = encoded

    for gi in 0..len(groups) {
        let g: FeedGroup = groups[gi];
        let gy: i32 = draw_y;
        if gy >= py and gy < py + panel_h - ROW_H {
            // Highlight if selected
            if g.id == sel_group and sel_feed < 0 {
                gfx_fill_rect(px, gy, tree_w - 1, ROW_H, SELECT_BG);
            };

            // Expand/collapse arrow
            let arrow: str = if g.expanded { "v" } else { ">" };
            gfx_draw_text(px + 6, gy + 4, arrow, DIM_COLOR, 0);

            // Group name
            let gname: str = truncate_str(g.name, 20);
            gfx_draw_text(px + 20, gy + 4, gname, GROUP_COLOR, 0);

            // Unread badge
            let gunread: i32 = count_group_unread(posts, feeds, g.id, read_guids);
            if gunread > 0 {
                let badge: str = "({gunread})";
                gfx_draw_text(px + 22 + str_len(gname) * 8, gy + 4, badge, BADGE_COLOR, 0);
            };

            // Click detection for group
            let mx: i32 = canvas_mouse_x();
            let my: i32 = canvas_mouse_y();
            let mbtn: i32 = canvas_mouse_btn();
            if ui_in_rect(mx, my, px, gy, tree_w, ROW_H) and band(mbtn, 1) == 1 and band(prev_btn, 1) == 0 {
                clicked_type = 10000 + gi;
            };
        };
        draw_y += ROW_H;

        // Draw feeds under this group if expanded.
        // Two passes: healthy feeds first, failed feeds (in red) at the bottom.
        if g.expanded {
            for pass in 0..2 {
                for fi3 in 0..len(feeds) {
                    if feeds[fi3].group_id == g.id {
                        let fkey: str = i32_to_str(feeds[fi3].id);
                        let has_err: bool = map_has(failed_feeds, fkey);
                        let is_err_pass: bool = pass == 1;
                        if has_err == is_err_pass {
                            let fy: i32 = draw_y;
                            if fy >= py and fy < py + panel_h - ROW_H {
                                if feeds[fi3].id == sel_feed {
                                    gfx_fill_rect(px, fy, tree_w - 1, ROW_H, SELECT_BG);
                                };

                                let marker: str = if has_err { "!" } else { "*" };
                                let marker_color: i32 = if has_err { ERROR_COLOR } else { DIM_COLOR };
                                gfx_draw_text(px + 24, fy + 4, marker, marker_color, 0);
                                let fname: str = truncate_str(feeds[fi3].name, 18);
                                let fname_color: i32 = if has_err { ERROR_COLOR } else { TEXT_COLOR };
                                gfx_draw_text(px + 36, fy + 4, fname, fname_color, 0);

                                if not has_err {
                                    let funread: i32 = count_unread(posts, feeds[fi3].id, read_guids);
                                    if funread > 0 {
                                        let fbadge: str = "({funread})";
                                        gfx_draw_text(px + 38 + str_len(fname) * 8, fy + 4, fbadge, BADGE_COLOR, 0);
                                    };
                                };

                                let mx2: i32 = canvas_mouse_x();
                                let my2: i32 = canvas_mouse_y();
                                let mbtn2: i32 = canvas_mouse_btn();
                                if ui_in_rect(mx2, my2, px, fy, tree_w, ROW_H) and band(mbtn2, 1) == 1 and band(prev_btn, 1) == 0 {
                                    clicked_type = 20000 + fi3;
                                };
                            };
                            draw_y += ROW_H;
                        };
                    };
                };
            };
        };
    };

    clicked_type
}

fn! render_post_list(posts: [Post], sel_feed: i32, sel_post: i32,
                     read_guids: map, filter_mode: i32,
                     read_at_startup: map,
                     list_scroll: i32, panel_x: i32, panel_w: i32,
                     panel_h: i32, prev_btn: i32, list_h: i32,
                     status_msg: str) -> i32 {
    let py: i32 = CHROME_H;
    let max_y: i32 = py + list_h;
    gfx_fill_rect(panel_x, py, panel_w, list_h, BG_COLOR);

    // Header
    gfx_draw_text(panel_x + 8, py + 6, "Posts", TITLE_COLOR, 0);
    gfx_line(panel_x, py + ROW_H, panel_x + panel_w, py + ROW_H, BORDER_COLOR);

    let mut draw_y: i32 = py + ROW_H + 4 - list_scroll;
    let mut clicked_post: i32 = -1;
    let mut visible_idx: i32 = 0;

    for pi in 0..len(posts) {
        let pi_match: bool = posts[pi].feed_id == sel_feed;
        let is_read: bool = map_has(read_guids, posts[pi].guid);
        let was_read_at_startup: bool = map_has(read_at_startup, posts[pi].guid);
        // filter_mode: 0=session, 1=all, 2=unread
        let pi_filtered: bool = if filter_mode == 2 {
            is_read
        } else if filter_mode == 1 {
            false
        } else {
            // Session view: only posts unread at startup, still shown
            // when they've been read this session (so clicking doesn't
            // make them vanish) — rendered dimmed via is_read below.
            was_read_at_startup
        };

        if pi_match and not pi_filtered {
            if draw_y >= py + ROW_H and draw_y < max_y - ROW_H {
                // Selection highlight
                if pi == sel_post {
                    gfx_fill_rect(panel_x, draw_y - 2, panel_w, ROW_H + 4, SELECT_BG);
                };

                // Read/unread indicator
                let indicator: str = if is_read { "o" } else { "*" };
                let ind_color: i32 = if is_read { READ_COLOR } else { UNREAD_COLOR };
                gfx_draw_text(panel_x + 8, draw_y + 2, indicator, ind_color, 0);

                // Title
                let max_title: i32 = (panel_w - 100) / 8;
                let ptitle: str = truncate_str(posts[pi].title, max_title);
                let title_color: i32 = if is_read { DIM_COLOR } else { TEXT_COLOR };
                gfx_draw_text(panel_x + 22, draw_y + 2, ptitle, title_color, 0);

                // Date (right-aligned, truncated)
                let pdate: str = truncate_str(posts[pi].pub_date, 16);
                let date_x: i32 = panel_x + panel_w - str_len(pdate) * 8 - 8;
                gfx_draw_text(date_x, draw_y + 2, pdate, DIM_COLOR, 0);

                // Click detection
                let mx3: i32 = canvas_mouse_x();
                let my3: i32 = canvas_mouse_y();
                let mbtn3: i32 = canvas_mouse_btn();
                if ui_in_rect(mx3, my3, panel_x, draw_y - 2, panel_w, ROW_H + 4) and band(mbtn3, 1) == 1 and band(prev_btn, 1) == 0 {
                    clicked_post = pi;
                };
            };

            draw_y += ROW_H + 2;
            visible_idx += 1;
        };
    };

    // Separator below post list
    gfx_line(panel_x, py + list_h, panel_x + panel_w, py + list_h, BORDER_COLOR);

    // If nothing was rendered and the last status looks like a fetch
    // error, display it inside the pane so it's obvious why.
    if visible_idx == 0 and sel_feed > 0 {
        let is_err: bool = str_starts_with(status_msg, "Failed:") or str_starts_with(status_msg, "No items:");
        if is_err {
            let max_chars: i32 = (panel_w - 24) / 8;
            let msg_line: str = truncate_str(status_msg, max_chars);
            gfx_draw_text(panel_x + 12, py + ROW_H + 12, msg_line, UNREAD_COLOR, 0);
        };
    };

    clicked_post
}

fn! render_post_content(posts: [Post], sel_post: i32, panel_x: i32,
                        panel_w: i32, content_y: i32, content_h: i32,
                        content_scroll: i32,
                        content_links: [LinkRegion],
                        img_cache_idx: map, img_cache_data: [[i32]],
                        img_cache_w: [i32], img_cache_h: [i32]) {
    gfx_fill_rect(panel_x, content_y, panel_w, content_h, BG_COLOR);

    // Clear link regions from previous frame
    while len(content_links) > 0 { pop(content_links); };

    if sel_post < 0 or sel_post >= len(posts) {
        gfx_draw_text(panel_x + 20, content_y + 20, "Select a post to read", DIM_COLOR, 0);
        return;
    };

    let post: Post = posts[sel_post];

    // Header area (title, date, link)
    let header_h: i32 = 60;
    let mut cy: i32 = content_y + 8 - content_scroll;

    // Title
    if cy >= content_y and cy < content_y + content_h {
        gfx_draw_text(panel_x + 8, cy, post.title, TITLE_COLOR, 0);
    };
    cy += 18;

    // Date
    if cy >= content_y and cy < content_y + content_h {
        gfx_draw_text(panel_x + 8, cy, post.pub_date, DIM_COLOR, 0);
    };
    cy += 14;

    // Link (clickable — register as link region)
    let link_disp: str = truncate_str(post.link, 60);
    if cy >= content_y and cy < content_y + content_h {
        gfx_draw_text(panel_x + 8, cy, link_disp, LINK_COLOR, 0);
        gfx_line(panel_x + 8, cy + 10, panel_x + 8 + str_len(link_disp) * 8, cy + 10, LINK_COLOR);
        let header_link: LinkRegion = LinkRegion {
            x: panel_x + 8, y: cy,
            w: str_len(link_disp) * 8, h: 14,
            href: post.link,
        };
        push(content_links, header_link);
    };
    cy += 18;

    // Separator
    if cy >= content_y and cy < content_y + content_h {
        gfx_line(panel_x + 8, cy, panel_x + panel_w - 8, cy, BORDER_COLOR);
    };
    cy += 10;

    // Render HTML description.
    // IMPORTANT: pass content_y (NOT desc_y) as panel_y so that min_y
    // clipping inside html_render_content uses the TRUE content-viewport
    // top. Otherwise text scrolled into the header region would bleed
    // upward into the post list panel above.
    if str_len(post.description) > 0 {
        let html_scroll: i32 = content_scroll - header_h;
        let _total_h: i32 = html_render_content(post.description,
                                                 panel_x, content_y,
                                                 panel_w, content_h,
                                                 html_scroll,
                                                 content_links,
                                                 img_cache_idx, img_cache_data,
                                                 img_cache_w, img_cache_h,
                                                 post.link);
    };
}

fn! render_dialog(mode: AppMode, buf1: [i32], buf2: [i32],
                  cur1: [i32], cur2: [i32],
                  focused_field: i32, key: i32, prev_btn: i32,
                  w: i32, h: i32) -> i32 {
    // Returns: 0=pending, 1=OK, 2=Cancel
    let dw: i32 = 400;
    let dh: i32 = 180;
    let dx: i32 = (w - dw) / 2;
    let dy: i32 = (h - dh) / 2;

    // Dim background
    gfx_fill_rect(0, 0, w, h, rgb(0, 0, 0));

    // Dialog panel
    gfx_fill_rect(dx, dy, dw, dh, DIALOG_BG);
    gfx_rect(dx, dy, dw, dh, UI_ACCENT);

    // Title
    let title: str = match mode {
        AppMode::AddGroup => { "Add Group" },
        AppMode::EditGroup => { "Edit Group" },
        AppMode::AddFeed => { "Add Feed" },
        AppMode::EditFeed => { "Edit Feed" },
        AppMode::Confirm => { "Confirm Delete" },
        AppMode::ImportOpml => { "Import OPML" },
        AppMode::Normal => { "Dialog" },
    };
    gfx_draw_text(dx + 10, dy + 8, title, TITLE_COLOR, 0);
    gfx_line(dx, dy + 24, dx + dw, dy + 24, BORDER_COLOR);

    let mut result: i32 = 0;

    match mode {
        AppMode::AddGroup => {
            gfx_draw_text(dx + 10, dy + 34, "Group Name:", TEXT_COLOR, 0);
            let _f1: bool = ui_textbox(dx + 10, dy + 50, dw - 20, buf1, cur1, true, prev_btn, key);
        },
        AppMode::EditGroup => {
            gfx_draw_text(dx + 10, dy + 34, "Group Name:", TEXT_COLOR, 0);
            let _f2: bool = ui_textbox(dx + 10, dy + 50, dw - 20, buf1, cur1, true, prev_btn, key);
        },
        AppMode::AddFeed => {
            gfx_draw_text(dx + 10, dy + 34, "Feed Name:", TEXT_COLOR, 0);
            let _f3: bool = ui_textbox(dx + 10, dy + 50, dw - 20, buf1, cur1, focused_field == 0, prev_btn, key);
            gfx_draw_text(dx + 10, dy + 78, "Feed URL:", TEXT_COLOR, 0);
            let _f4: bool = ui_textbox(dx + 10, dy + 94, dw - 20, buf2, cur2, focused_field == 1, prev_btn, key);
        },
        AppMode::EditFeed => {
            gfx_draw_text(dx + 10, dy + 34, "Feed Name:", TEXT_COLOR, 0);
            let _f5: bool = ui_textbox(dx + 10, dy + 50, dw - 20, buf1, cur1, focused_field == 0, prev_btn, key);
            gfx_draw_text(dx + 10, dy + 78, "Feed URL:", TEXT_COLOR, 0);
            let _f6: bool = ui_textbox(dx + 10, dy + 94, dw - 20, buf2, cur2, focused_field == 1, prev_btn, key);
        },
        AppMode::Confirm => {
            gfx_draw_text(dx + 10, dy + 50, "Are you sure you want to delete?", TEXT_COLOR, 0);
        },
        AppMode::ImportOpml => {
            gfx_draw_text(dx + 10, dy + 34, "OPML file path:", TEXT_COLOR, 0);
            let _fi: bool = ui_textbox(dx + 10, dy + 50, dw - 20, buf1, cur1, true, prev_btn, key);
            gfx_draw_text(dx + 10, dy + 78, "Groups & feeds are appended; duplicates skipped.", DIM_COLOR, 0);
        },
        _ => {},
    };

    // OK / Cancel buttons
    let btn_y: i32 = dy + dh - 34;
    if ui_button(dx + dw - 180, btn_y, 80, BTN_H, "OK", prev_btn) {
        result = 1;
    };
    if ui_button(dx + dw - 90, btn_y, 80, BTN_H, "Cancel", prev_btn) {
        result = 2;
    };

    // Enter = OK, Escape = Cancel
    if key == 13 { result = 1; };
    if key == 27 { result = 2; };

    result
}

fn! render_help(w: i32, h: i32) {
    let dw: i32 = 350;
    let dh: i32 = 320;
    let dx: i32 = (w - dw) / 2;
    let dy: i32 = (h - dh) / 2;

    gfx_fill_rect(dx, dy, dw, dh, DIALOG_BG);
    gfx_rect(dx, dy, dw, dh, UI_ACCENT);
    gfx_draw_text(dx + 10, dy + 8, "Keyboard Shortcuts", TITLE_COLOR, 0);
    gfx_line(dx, dy + 24, dx + dw, dy + 24, BORDER_COLOR);

    let mut hy: i32 = dy + 32;
    let hx: i32 = dx + 10;
    let hx2: i32 = dx + 100;
    gfx_draw_text(hx, hy, "j / k", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Navigate up/down", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "Enter", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Select / expand", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "Tab", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Switch panel", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "a", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Add group/feed", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "e", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Edit selected", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "d", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Delete selected", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "r", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Refresh feed", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "R", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Refresh all", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "u", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Cycle filter (session/unread/all)", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "m", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Toggle read/unread", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "M", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Mark all read", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "Space", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Page article down (on post list)", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "Bksp", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Page article up (on post list)", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "?", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Toggle help", TEXT_COLOR, 0); hy += 16;
    gfx_draw_text(hx, hy, "q", UNREAD_COLOR, 0); gfx_draw_text(hx2, hy, "Quit", TEXT_COLOR, 0); hy += 16;

    gfx_draw_text(dx + 10, dy + dh - 20, "Press ? or Esc to close", DIM_COLOR, 0);
}

// ─── Main ────────────────────────────────────────────────

fn! main() {
    // Application state
    let mut groups: [FeedGroup] = [];
    let mut feeds: [Feed] = [];
    let mut posts: [Post] = [];
    let mut read_guids: map = map_new();
    let mut failed_feeds: map = map_new();

    // Load persisted data
    storage_load_groups(groups);
    storage_load_feeds(feeds);
    storage_load_read(read_guids);

    // UI state
    let mut sel_group: i32 = -1;
    let mut sel_feed: i32 = -1;
    let mut sel_post: i32 = -1;
    let mut focus_panel: i32 = 0; // 0=tree, 1=posts, 2=content
    // filter_mode: 0 = session (posts unread at startup, still visible when
    // read this session), 1 = All, 2 = Unread.
    let mut filter_mode: i32 = 0;
    let mut read_at_startup: map = map_new();
    let mut show_help: bool = false;
    let mut tree_scroll: i32 = 0;
    let mut list_scroll: i32 = 0;
    let mut content_scroll: i32 = 0;
    let mut prev_btn: i32 = 0;
    let mut status_msg: str = "Welcome to OscanRss";

    // Dialog state
    let mut mode: AppMode = AppMode::Normal;
    let mut dialog_buf1: [i32] = [];
    let mut dialog_buf2: [i32] = [];
    let mut dialog_cur1: [i32] = [0];
    let mut dialog_cur2: [i32] = [0];
    let mut dialog_field: i32 = 0;

    // Link and image state
    let mut content_links: [LinkRegion] = [];
    let mut img_cache_idx: map = map_new();
    let mut img_cache_data: [[i32]] = [];
    let mut img_cache_w: [i32] = [];
    let mut img_cache_h: [i32] = [];

    // Resizable pane layout
    let mut tree_w: i32 = TREE_W;
    let mut list_h: i32 = POST_SPLIT;
    let mut drag_v: bool = false; // dragging vertical splitter (tree_w)
    let mut drag_h: bool = false; // dragging horizontal splitter (list_h)

    // Select first group if available
    if len(groups) > 0 {
        sel_group = groups[0].id;
    };

    // Open canvas
    let open_result: Result<str, str> = canvas_open(WIN_W, WIN_H, "OscanRss");
    match open_result {
        Result::Ok(_s) => {},
        Result::Err(e) => { println("Failed to open window: {e}"); exit(1); },
    };

    // Replace Oscan's default retro "O" with our retro "R" icon.
    let icon_px: [i32] = icon_build_pixels();
    let _icon_res: Result<str, str> = canvas_set_icon(icon_px, 32, 32);

    // On startup, try to fetch every feed so errored feeds can be
    // marked in the tree. This blocks until all feeds are tried.
    if len(feeds) > 0 {
        status_msg = refresh_all_feeds(feeds, posts, read_guids, failed_feeds, true);
    };

    // Snapshot the read-guid set *after* the startup fetch so the
    // "session" filter can show every post that was unread when the
    // app started — even after the user reads some of them this run.
    for si in 0..len(posts) {
        if map_has(read_guids, posts[si].guid) {
            map_set(read_at_startup, posts[si].guid, "1");
        };
    };

    while canvas_alive() {
        let key: i32 = canvas_key();
        let w: i32 = canvas_width();
        let h: i32 = canvas_height();
        let wheel: i32 = canvas_wheel();
        let panel_w: i32 = w - tree_w;
        let panel_h: i32 = h - CHROME_H - STATUS_H;
        let content_y: i32 = CHROME_H + list_h;
        let content_h: i32 = h - CHROME_H - list_h - STATUS_H;

        // ─── Input handling (outside rendering) ──────────

        let mut is_normal: bool = false;
        match mode {
            AppMode::Normal => { is_normal = true; },
            _ => {},
        };

        if is_normal and not show_help {
            // Keyboard shortcuts
            if key == 113 { // 'q'
                break;
            };
            if key == 63 { // '?'
                show_help = true;
            };
            if key == 9 { // Tab
                focus_panel = mod_i32(focus_panel + 1, 3);
            };
            if key == 117 { // 'u' — cycle: session -> unread -> all -> session
                if filter_mode == 0 { filter_mode = 2; }
                else if filter_mode == 2 { filter_mode = 1; }
                else { filter_mode = 0; };
            };

            // Navigation
            if key == 106 or key == 107 { // j/k
                if focus_panel == 0 {
                    // Tree navigation — walk linearly through visible
                    // entries (groups and, if group expanded, feeds).
                    // Entries are encoded as: group_id or 100000+feed_id.
                    let mut entries: [i32] = [];
                    for tgi in 0..len(groups) {
                        push(entries, groups[tgi].id);
                        if groups[tgi].expanded {
                            for tfi in 0..len(feeds) {
                                if feeds[tfi].group_id == groups[tgi].id {
                                    push(entries, 100000 + feeds[tfi].id);
                                };
                            };
                        };
                    };
                    // Find current selection index in entries
                    let mut cur_idx: i32 = -1;
                    let cur_token: i32 = if sel_feed >= 0 { 100000 + sel_feed } else { sel_group };
                    for tei in 0..len(entries) {
                        if entries[tei] == cur_token { cur_idx = tei; };
                    };
                    let mut new_idx: i32 = cur_idx;
                    if key == 106 and cur_idx + 1 < len(entries) {
                        new_idx = cur_idx + 1;
                    };
                    if key == 107 and cur_idx > 0 {
                        new_idx = cur_idx - 1;
                    };
                    if key == 106 and cur_idx < 0 and len(entries) > 0 {
                        new_idx = 0;
                    };
                    if new_idx >= 0 and new_idx < len(entries) and new_idx != cur_idx {
                        let token: i32 = entries[new_idx];
                        if token >= 100000 {
                            // Feed entry — auto-refresh on selection
                            let fid: i32 = token - 100000;
                            sel_feed = fid;
                            for tfl in 0..len(feeds) {
                                if feeds[tfl].id == fid {
                                    sel_group = feeds[tfl].group_id;
                                    status_msg = "Loading {feeds[tfl].name}...";
                                    status_msg = fetch_and_track(feeds, tfl, posts, read_guids, failed_feeds);
                                };
                            };
                            sel_post = -1;
                            list_scroll = 0;
                            content_scroll = 0;
                        } else {
                            // Group entry
                            sel_group = token;
                            sel_feed = -1;
                            sel_post = -1;
                        };
                    };
                } else if focus_panel == 1 {
                    // Post list navigation
                    if key == 106 { // j
                        let mut next_post: i32 = -1;
                        let mut found_cur: bool = false;
                        for pn in 0..len(posts) {
                            let pn_ok: bool = posts[pn].feed_id == sel_feed and (if filter_mode == 2 { not map_has(read_guids, posts[pn].guid) } else if filter_mode == 1 { true } else { not map_has(read_at_startup, posts[pn].guid) });
                            if pn_ok {
                                if found_cur and next_post < 0 { next_post = pn; };
                                if pn == sel_post { found_cur = true; };
                                if sel_post < 0 and next_post < 0 { next_post = pn; };
                            };
                        };
                        if next_post >= 0 {
                            sel_post = next_post;
                            content_scroll = 0;
                            map_set(read_guids, posts[sel_post].guid, "1");
                            do_save_read(posts, read_guids);
                        };
                    };
                    if key == 107 { // k
                        let mut prev_post: i32 = -1;
                        let mut found_sel: bool = false;
                        for pp in 0..len(posts) {
                            let pp_ok: bool = posts[pp].feed_id == sel_feed and (if filter_mode == 2 { not map_has(read_guids, posts[pp].guid) } else if filter_mode == 1 { true } else { not map_has(read_at_startup, posts[pp].guid) });
                            if pp_ok {
                                if pp == sel_post { found_sel = true; };
                                if not found_sel { prev_post = pp; };
                            };
                        };
                        if prev_post >= 0 {
                            sel_post = prev_post;
                            content_scroll = 0;
                            map_set(read_guids, posts[sel_post].guid, "1");
                            do_save_read(posts, read_guids);
                        };
                    };
                } else {
                    // Content pane: j/k = scroll down/up
                    let step: i32 = 14;
                    if key == 106 { // j = down
                        content_scroll = content_scroll + step;
                    };
                    if key == 107 { // k = up
                        content_scroll = max_i32(0, content_scroll - step);
                    };
                };
            };

            // Enter: expand/collapse group (panel 0), or scroll content
            // down when focused on post list (panel 1).
            if key == 13 {
                if focus_panel == 0 and sel_group >= 0 {
                    for ge in 0..len(groups) {
                        if groups[ge].id == sel_group {
                            groups[ge].expanded = not groups[ge].expanded;
                            storage_save_groups(groups);
                            break;
                        };
                    };
                } else if focus_panel == 1 {
                    content_scroll = content_scroll + content_h;
                };
            };

            // Backspace on post list: scroll content up one screen
            if key == 8 and focus_panel == 1 {
                content_scroll = max_i32(0, content_scroll - content_h);
            };

            // Space on post list: page the article text down (Shift+Space
            // / '-' to page back up). Mirrors classic feed-reader UX.
            if key == 32 and focus_panel == 1 {
                content_scroll = content_scroll + content_h;
            };

            // 'a' = add
            if key == 97 {
                if focus_panel == 0 {
                    if sel_feed >= 0 or (sel_group >= 0 and len(groups) > 0) {
                        mode = AppMode::AddFeed;
                        while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                        while len(dialog_buf2) > 0 { pop(dialog_buf2); };
                        dialog_cur1[0] = 0;
                        dialog_cur2[0] = 0;
                        dialog_field = 0;
                    } else {
                        mode = AppMode::AddGroup;
                        while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                        dialog_cur1[0] = 0;
                    };
                } else {
                    mode = AppMode::AddGroup;
                    while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                    dialog_cur1[0] = 0;
                };
            };

            // 'e' = edit
            if key == 101 {
                if sel_feed >= 0 {
                    for ef in 0..len(feeds) {
                        if feeds[ef].id == sel_feed {
                            mode = AppMode::EditFeed;
                            str_to_buf(feeds[ef].name, dialog_buf1);
                            str_to_buf(feeds[ef].url, dialog_buf2);
                            dialog_cur1[0] = len(dialog_buf1);
                            dialog_cur2[0] = len(dialog_buf2);
                            dialog_field = 0;
                            break;
                        };
                    };
                } else if sel_group >= 0 {
                    for eg in 0..len(groups) {
                        if groups[eg].id == sel_group {
                            mode = AppMode::EditGroup;
                            str_to_buf(groups[eg].name, dialog_buf1);
                            dialog_cur1[0] = len(dialog_buf1);
                            break;
                        };
                    };
                };
            };

            // 'd' = delete
            if key == 100 {
                if sel_feed >= 0 or sel_group >= 0 {
                    mode = AppMode::Confirm;
                };
            };

            // 'r' = refresh selected feed
            if key == 114 {
                if sel_feed >= 0 {
                    for rf in 0..len(feeds) {
                        if feeds[rf].id == sel_feed {
                            status_msg = "Refreshing {feeds[rf].name}...";
                            status_msg = fetch_and_track(feeds, rf, posts, read_guids, failed_feeds);
                            break;
                        };
                    };
                };
            };

            // 'R' = refresh all
            if key == 82 {
                status_msg = "Refreshing all feeds...";
                status_msg = refresh_all_feeds(feeds, posts, read_guids, failed_feeds, true);
            };

            // 'm' = toggle read/unread
            if key == 109 {
                if sel_post >= 0 and sel_post < len(posts) {
                    let pguid: str = posts[sel_post].guid;
                    if map_has(read_guids, pguid) {
                        map_delete(read_guids, pguid);
                    } else {
                        map_set(read_guids, pguid, "1");
                    };
                    do_save_read(posts, read_guids);
                };
            };

            // 'M' = mark all read
            if key == 77 {
                if sel_feed >= 0 {
                    for ma in 0..len(posts) {
                        if posts[ma].feed_id == sel_feed {
                            map_set(read_guids, posts[ma].guid, "1");
                        };
                    };
                    do_save_read(posts, read_guids);
                    status_msg = "All posts marked as read";
                };
            };

            // Scroll
            if wheel != 0 {
                if focus_panel == 0 {
                    tree_scroll = max_i32(0, tree_scroll - wheel * ROW_H);
                } else if focus_panel == 1 {
                    list_scroll = max_i32(0, list_scroll - wheel * ROW_H);
                } else {
                    content_scroll = max_i32(0, content_scroll - wheel * 14);
                };
            };

            // Tab key in feed dialog to switch fields
        } else if show_help {
            if key == 63 or key == 27 { // '?' or Esc
                show_help = false;
            };
        };

        // ─── Rendering ───────────────────────────────────

        canvas_clear(BG_COLOR);

        // Chrome bar
        render_chrome(w);

        // Tree panel buttons
        let btn_x: i32 = 4;
        let btn_base_y: i32 = h - STATUS_H - BTN_H - 6;
        let add_group_clicked: bool = ui_button(btn_x, btn_base_y, 58, BTN_H, "+Group", prev_btn);
        let add_feed_clicked: bool = ui_button(btn_x + 62, btn_base_y, 56, BTN_H, "+Feed", prev_btn);
        let edit_clicked: bool = ui_button(btn_x + 122, btn_base_y, 50, BTN_H, "Edit", prev_btn);
        let del_clicked: bool = ui_button(btn_x + 176, btn_base_y, 50, BTN_H, "Del", prev_btn);
        let import_clicked: bool = ui_button(btn_x + 230, btn_base_y, 60, BTN_H, "Import", prev_btn);

        // View-filter toggle buttons: "All" and "Unread". When both
        // are off (pressed state cleared), the post list shows the
        // session view — posts that were unread at startup, with ones
        // read this session rendered dimmed.
        let all_selected: bool = filter_mode == 1;
        let unread_selected: bool = filter_mode == 2;
        let all_clicked: bool = ui_toggle_button(w - 160, 4, 70, BTN_H, "All", all_selected, prev_btn);
        let unread_clicked: bool = ui_toggle_button(w - 84, 4, 76, BTN_H, "Unread", unread_selected, prev_btn);

        // Handle button clicks (in Normal mode)
        if is_normal and not show_help {
            if add_group_clicked {
                mode = AppMode::AddGroup;
                while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                dialog_cur1[0] = 0;
            };
            if add_feed_clicked and sel_group >= 0 {
                mode = AppMode::AddFeed;
                while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                while len(dialog_buf2) > 0 { pop(dialog_buf2); };
                dialog_cur1[0] = 0;
                dialog_cur2[0] = 0;
                dialog_field = 0;
            };
            if edit_clicked {
                if sel_feed >= 0 {
                    for ef2 in 0..len(feeds) {
                        if feeds[ef2].id == sel_feed {
                            mode = AppMode::EditFeed;
                            str_to_buf(feeds[ef2].name, dialog_buf1);
                            str_to_buf(feeds[ef2].url, dialog_buf2);
                            dialog_cur1[0] = len(dialog_buf1);
                            dialog_cur2[0] = len(dialog_buf2);
                            dialog_field = 0;
                            break;
                        };
                    };
                } else if sel_group >= 0 {
                    for eg2 in 0..len(groups) {
                        if groups[eg2].id == sel_group {
                            mode = AppMode::EditGroup;
                            str_to_buf(groups[eg2].name, dialog_buf1);
                            dialog_cur1[0] = len(dialog_buf1);
                            break;
                        };
                    };
                };
            };
            if del_clicked and (sel_feed >= 0 or sel_group >= 0) {
                mode = AppMode::Confirm;
            };
            if import_clicked {
                mode = AppMode::ImportOpml;
                while len(dialog_buf1) > 0 { pop(dialog_buf1); };
                dialog_cur1[0] = 0;
                dialog_field = 0;
            };
            if all_clicked {
                if filter_mode == 1 { filter_mode = 0; } else { filter_mode = 1; };
            };
            if unread_clicked {
                if filter_mode == 2 { filter_mode = 0; } else { filter_mode = 2; };
            };
        };

        // Click-to-focus: pressing mouse in a pane focuses that pane.
        // Must run BEFORE the panel renders so the in-pane highlight
        // picks up the new focus on the same frame.
        {
            let fmx: i32 = canvas_mouse_x();
            let fmy: i32 = canvas_mouse_y();
            let fbtn: i32 = canvas_mouse_btn();
            if band(fbtn, 1) == 1 and band(prev_btn, 1) == 0 and is_normal {
                if fmy >= CHROME_H and fmy < h - STATUS_H {
                    if fmx < tree_w {
                        focus_panel = 0;
                    } else if fmy < CHROME_H + list_h {
                        focus_panel = 1;
                    } else {
                        focus_panel = 2;
                    };
                };
            };
        };

        // Tree panel
        let tree_click: i32 = render_tree_panel(groups, feeds, posts, read_guids,
                                                 sel_group, sel_feed, tree_scroll,
                                                 panel_h - BTN_H - 10, prev_btn,
                                                 tree_w, failed_feeds);
        if tree_click >= 20000 and is_normal {
            // Clicked a feed — select and auto-refresh so newly-arrived
            // posts show without the user having to press Refresh.
            let fidx: i32 = tree_click - 20000;
            if fidx >= 0 and fidx < len(feeds) {
                sel_feed = feeds[fidx].id;
                sel_group = feeds[fidx].group_id;
                sel_post = -1;
                list_scroll = 0;
                status_msg = "Loading {feeds[fidx].name}...";
                status_msg = fetch_and_track(feeds, fidx, posts, read_guids, failed_feeds);
            };
        } else if tree_click >= 10000 and is_normal {
            // Clicked a group
            let gidx: i32 = tree_click - 10000;
            if gidx >= 0 and gidx < len(groups) {
                sel_group = groups[gidx].id;
                sel_feed = -1;
                sel_post = -1;
                groups[gidx].expanded = not groups[gidx].expanded;
                storage_save_groups(groups);
            };
        };

        // Post list
        if sel_feed >= 0 {
            let post_click: i32 = render_post_list(posts, sel_feed, sel_post,
                                                    read_guids, filter_mode,
                                                    read_at_startup,
                                                    list_scroll, tree_w, panel_w,
                                                    panel_h, prev_btn, list_h,
                                                    status_msg);
            if post_click >= 0 and is_normal {
                sel_post = post_click;
                content_scroll = 0;
                // Auto-mark as read
                map_set(read_guids, posts[sel_post].guid, "1");
                do_save_read(posts, read_guids);
            };
        } else {
            gfx_fill_rect(tree_w, CHROME_H, panel_w, panel_h, BG_COLOR);
            gfx_draw_text(tree_w + 20, CHROME_H + 40, "Select a feed to view posts", DIM_COLOR, 0);
        };

        // Post content
        if sel_feed >= 0 {
            render_post_content(posts, sel_post, tree_w, panel_w,
                               content_y, content_h, content_scroll,
                               content_links,
                               img_cache_idx, img_cache_data,
                               img_cache_w, img_cache_h);

            // Link click detection: check if mouse click hit a link
            let lmx: i32 = canvas_mouse_x();
            let lmy: i32 = canvas_mouse_y();
            let lbtn: i32 = canvas_mouse_btn();
            if band(lbtn, 1) == 1 and band(prev_btn, 1) == 0 and is_normal {
                for lk in 0..len(content_links) {
                    let lr: LinkRegion = content_links[lk];
                    if ui_in_rect(lmx, lmy, lr.x, lr.y, lr.w, lr.h) {
                        if str_len(lr.href) > 0 {
                            open_url_in_browser(lr.href);
                            status_msg = "Opened: {lr.href}";
                        };
                    };
                };
            };
        };

        // Status bar
        let mut total_unread: i32 = 0;
        for tu in 0..len(posts) {
            if not map_has(read_guids, posts[tu].guid) {
                total_unread += 1;
            };
        };
        render_status(w, h, total_unread, status_msg);

        // Dialog overlay
        let mut is_dialog: bool = false;
        match mode {
            AppMode::Normal => {},
            _ => { is_dialog = true; },
        };

        if is_dialog {
            let dialog_key: i32 = if is_dialog { key } else { 0 };
            // Tab between fields in feed dialogs
            let mut use_field: i32 = dialog_field;
            let mut is_feed_dialog: bool = false;
            match mode {
                AppMode::AddFeed => { is_feed_dialog = true; },
                AppMode::EditFeed => { is_feed_dialog = true; },
                _ => {},
            };
            if is_feed_dialog and dialog_key == 9 {
                use_field = mod_i32(dialog_field + 1, 2);
                dialog_field = use_field;
            };

            let dres: i32 = render_dialog(mode, dialog_buf1, dialog_buf2,
                                          dialog_cur1, dialog_cur2,
                                           dialog_field, dialog_key, prev_btn, w, h);

            if dres == 1 { // OK
                match mode {
                    AppMode::AddGroup => {
                        let gname_new: str = text_buf_to_str(dialog_buf1);
                        if str_len(gname_new) > 0 {
                            let mut id_list: [i32] = [];
                            for ag in 0..len(groups) { push(id_list, groups[ag].id); };
                            let new_id: i32 = next_id(id_list);
                            let new_group: FeedGroup = FeedGroup {
                                id: new_id, name: gname_new, expanded: true,
                            };
                            push(groups, new_group);
                            sel_group = new_id;
                            storage_save_groups(groups);
                            status_msg = "Group added: {gname_new}";
                        };
                    },
                    AppMode::EditGroup => {
                        let new_name: str = text_buf_to_str(dialog_buf1);
                        if str_len(new_name) > 0 {
                            for ug in 0..len(groups) {
                                if groups[ug].id == sel_group {
                                    groups[ug].name = new_name;
                                    break;
                                };
                            };
                            storage_save_groups(groups);
                            status_msg = "Group renamed";
                        };
                    },
                    AppMode::AddFeed => {
                        let fname_new: str = text_buf_to_str(dialog_buf1);
                        let furl_new: str = text_buf_to_str(dialog_buf2);
                        if str_len(fname_new) > 0 and str_len(furl_new) > 0 and sel_group >= 0 {
                            let mut fid_list: [i32] = [];
                            for af in 0..len(feeds) { push(fid_list, feeds[af].id); };
                            let new_fid: i32 = next_id(fid_list);
                            let new_feed: Feed = Feed {
                                id: new_fid, group_id: sel_group,
                                name: fname_new, url: furl_new,
                            };
                            push(feeds, new_feed);
                            sel_feed = new_fid;
                            storage_save_feeds(feeds);
                            status_msg = "Feed added: {fname_new}";
                            // Fetch posts (new feed is the last one pushed)
                            status_msg = fetch_and_track(feeds, len(feeds) - 1, posts, read_guids, failed_feeds);
                        };
                    },
                    AppMode::EditFeed => {
                        let ef_name: str = text_buf_to_str(dialog_buf1);
                        let ef_url: str = text_buf_to_str(dialog_buf2);
                        if str_len(ef_name) > 0 and str_len(ef_url) > 0 {
                            for uf in 0..len(feeds) {
                                if feeds[uf].id == sel_feed {
                                    feeds[uf].name = ef_name;
                                    feeds[uf].url = ef_url;
                                    break;
                                };
                            };
                            storage_save_feeds(feeds);
                            status_msg = "Feed updated";
                        };
                    },
                    AppMode::Confirm => {
                        // Delete
                        if sel_feed >= 0 {
                            // Remove feed's posts
                            let mut di: i32 = len(posts) - 1;
                            while di >= 0 {
                                if posts[di].feed_id == sel_feed {
                                    let dlast: i32 = len(posts) - 1;
                                    if di < dlast { posts[di] = posts[dlast]; };
                                    pop(posts);
                                };
                                di -= 1;
                            };
                            // Remove the feed
                            let mut di2: i32 = len(feeds) - 1;
                            while di2 >= 0 {
                                if feeds[di2].id == sel_feed {
                                    let dlast2: i32 = len(feeds) - 1;
                                    if di2 < dlast2 { feeds[di2] = feeds[dlast2]; };
                                    pop(feeds);
                                    break;
                                };
                                di2 -= 1;
                            };
                            sel_feed = -1;
                            sel_post = -1;
                            storage_save_feeds(feeds);
                            status_msg = "Feed deleted";
                        } else if sel_group >= 0 {
                            // Remove all feeds in group
                            let mut di3: i32 = len(feeds) - 1;
                            while di3 >= 0 {
                                if feeds[di3].group_id == sel_group {
                                    // Remove posts for this feed
                                    let del_fid: i32 = feeds[di3].id;
                                    let mut di4: i32 = len(posts) - 1;
                                    while di4 >= 0 {
                                        if posts[di4].feed_id == del_fid {
                                            let dlast4: i32 = len(posts) - 1;
                                            if di4 < dlast4 { posts[di4] = posts[dlast4]; };
                                            pop(posts);
                                        };
                                        di4 -= 1;
                                    };
                                    let dlast3: i32 = len(feeds) - 1;
                                    if di3 < dlast3 { feeds[di3] = feeds[dlast3]; };
                                    pop(feeds);
                                };
                                di3 -= 1;
                            };
                            // Remove the group
                            let mut di5: i32 = len(groups) - 1;
                            while di5 >= 0 {
                                if groups[di5].id == sel_group {
                                    let dlast5: i32 = len(groups) - 1;
                                    if di5 < dlast5 { groups[di5] = groups[dlast5]; };
                                    pop(groups);
                                    break;
                                };
                                di5 -= 1;
                            };
                            sel_group = if len(groups) > 0 { groups[0].id } else { -1 };
                            sel_feed = -1;
                            sel_post = -1;
                            storage_save_groups(groups);
                            storage_save_feeds(feeds);
                            status_msg = "Group deleted";
                        };
                    },
                    AppMode::ImportOpml => {
                        let opml_path: str = str_trim(text_buf_to_str(dialog_buf1));
                        if str_len(opml_path) == 0 {
                            status_msg = "Import cancelled: no path provided";
                        } else {
                            let r: Result<str, str> = read_file(opml_path);
                            match r {
                                Result::Ok(body) => {
                                    let n_added: i32 = opml_import(body, groups, feeds);
                                    storage_save_groups(groups);
                                    storage_save_feeds(feeds);
                                    status_msg = "Imported {n_added} new feed(s) from OPML";
                                },
                                Result::Err(e) => {
                                    status_msg = "Failed to read OPML: {e}";
                                },
                            };
                        };
                    },
                    _ => {},
                };
                mode = AppMode::Normal;
            };
            if dres == 2 { // Cancel
                mode = AppMode::Normal;
            };
        };

        // Help overlay
        if show_help {
            render_help(w, h);
        };

        // ─── Splitter handles (drag to resize panes) ─────
        // Vertical splitter at x = tree_w: drag to resize left tree panel
        // Horizontal splitter at y = CHROME_H + list_h: drag to resize post list (only when a feed is selected)
        {
            let smx: i32 = canvas_mouse_x();
            let smy: i32 = canvas_mouse_y();
            let sbtn: i32 = canvas_mouse_btn();
            let pressed: bool = band(sbtn, 1) == 1 and band(prev_btn, 1) == 0;
            let released: bool = band(sbtn, 1) == 0;
            let held: bool = band(sbtn, 1) == 1;

            let v_x: i32 = tree_w;
            let v_y0: i32 = CHROME_H;
            let v_y1: i32 = h - STATUS_H;
            let v_hover: bool = smx >= v_x - 3 and smx <= v_x + 3 and smy >= v_y0 and smy < v_y1;

            let h_x0: i32 = tree_w;
            let h_x1: i32 = w;
            let h_y: i32 = CHROME_H + list_h;
            let h_hover: bool = sel_feed >= 0 and smy >= h_y - 3 and smy <= h_y + 3 and smx >= h_x0 and smx < h_x1;

            if pressed and is_normal {
                if v_hover and not h_hover { drag_v = true; };
                if h_hover and not v_hover { drag_h = true; };
            };
            if released {
                drag_v = false;
                drag_h = false;
            };

            if drag_v and held {
                tree_w = smx;
                if tree_w < 150 { tree_w = 150; };
                if tree_w > w - 250 { tree_w = w - 250; };
            };
            if drag_h and held {
                list_h = smy - CHROME_H;
                let min_list: i32 = 80;
                let max_list: i32 = h - CHROME_H - STATUS_H - 120;
                if list_h < min_list { list_h = min_list; };
                if list_h > max_list { list_h = max_list; };
            };

            // Highlight splitter handles on hover/drag (subtle accent)
            let v_color: i32 = if v_hover or drag_v { LINK_COLOR } else { BORDER_COLOR };
            gfx_fill_rect(v_x - 1, v_y0, 3, v_y1 - v_y0, v_color);
            if sel_feed >= 0 {
                let hc: i32 = if h_hover or drag_h { LINK_COLOR } else { BORDER_COLOR };
                gfx_fill_rect(h_x0, h_y - 1, h_x1 - h_x0, 3, hc);
            };
        };

        // Update prev_btn
        prev_btn = canvas_mouse_btn();

        canvas_flush();
        sleep_ms(16);
    };

    canvas_close();
}
